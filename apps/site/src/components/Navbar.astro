---
// dependency imports
import { Icon } from "astro-icon/components";

// component imports
import Logo from "@/components/Logo.astro";

// data imports
import { getMetadataEntry } from "@/data/metadata";
import { getCurrentLanguage, useTranslatedPath, useTranslations } from "@/i18n/utils";

const lang = getCurrentLanguage(Astro);
const metadata = await getMetadataEntry(lang);

const links = [
  { href: "#about", label: "about" },
  { href: "#experience", label: "experience" },
  { href: "#projects", label: "work" },
  { href: "#contact", label: "contact" },
];
---

<header id="navbar">
  <nav class="nav-container">
    <div class="nav-home">
      <!-- Desktop Logo -->
      <Logo src="/logo-sn1o-lg.svg" href="/" width={148} height={33} class="logomark-lg" />

      <!-- Mobile Logo -->
      <Logo src="/logo-sn1o-sm.svg" href="/" width={48} height={33} class="logomark-sm" />
    </div>

    <div class="nav-home-lang">
      <span><a href="/">pt-br</a> | <a href="/en">en</a></span>
    </div>

    <!-- Desktop Menu -->
    <div id="nav-menu" class="nav-menu">
      <ul class="nav-menu-list">
        {links.map((link, idx) =>(
        <li>
          <a href={link.href}>
            <span>{`0${idx+1}.`}</span> {link.label}
          </a>
        </li>
        ))}
        <a class="button-sm" href={metadata.resume} target="_blank">Resume</a>
      </ul>
    </div>

    <!-- Hamburguer button -->
    <button id="nav-hamburguer" class="nav-hamburguer" aria-label="Toggle Menu" aria-expanded="false">
      <Icon class="nav-hamburguer-menu" name="mdi:menu" width={38} height={38} />
      <Icon class="nav-hamburguer-close" name="mdi:close-circle-outline" width={38} height={38} />
    </button>
  </nav>

  <!-- Mobile Menu -->
  <div id="nav-menu-mobile" class="nav-menu-mobile">
    <ul class="nav-menu-mobile-list">
      {links.map((link, idx) =>(
      <li>
        <a href={link.href}>
          <span>{`0${idx+1}.`}</span> {link.label}
        </a>
      </li>
      ))}
      <a class="button-md" href={metadata.resume}>Resume</a>
    </ul>
  </div>
</header>

<script>
  import "@/styles/navbar.js";
</script>
