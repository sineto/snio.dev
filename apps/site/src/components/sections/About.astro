---
import { Icon } from "astro-icon/components";
import { type Card } from "@/data/about";

interface Props {
  aboutStack: string[];
  aboutCards: Card[];
}

const { aboutStack, aboutCards } = Astro.props as Props;
---
<section id="about">
  <div class="about-intro">
    <h2 class="section-header">Introduce</h2>
      <slot />
    <ul>
      {aboutStack && (aboutStack.map((item: string) => (
        <li>{item}</li>
      )))}
    </ul>
  </div>
  <div class="about-cards">
    {aboutCards && (aboutCards.map((card: Card) => (
      <ul>
        <li>
          <span>
            {card.title} <Icon name={card.iconName} />
          </span>
          <p>{card.tldr}</p>
        </li>
        <a href="">clients</a>
      </ul>
    )))}
  </div>
</section>
