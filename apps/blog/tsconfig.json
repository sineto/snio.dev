{
  "extends": [
    "@repo/typescript-config/base.json",
    "astro/tsconfigs/strict"
  ],
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "**/*.astro",
    ".astro/types.d.ts"
  ],
  "exclude": [
    "dist",
    "node_modules",
    ".astro"
  ],
  "compileOptions": {
    "paths": {
      "@/*": [
        "src/*"
      ]
    }
  }
}
